{
  "name": "fiber-wasm-testnet-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test-peer-connection-target.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "ci:scenario": "node scripts/run-scenario-ci.mjs",
    "fiber-js:local": "bash scripts/use-local-fiber-js.sh",
    "fiber-js:restore": "bash scripts/use-local-fiber-js.sh --restore"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.12.5",
    "@nervosnetwork/fiber-js": "0.9.0-rc5",
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
